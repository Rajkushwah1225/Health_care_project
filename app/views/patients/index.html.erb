<h1>Patients</h1>
<table class="table table-striped">
  <thead>
    <tr>
      <th>First name</th>
      <th>Last name</th>
      <th>DOB</th>
      <th colspan="3"></th>
    </tr>
  </thead>

    <tbody>
        <% @patients.each do |patient| %>
            <tr>
            <td><%= patient.first_name %></td>
            <td><%= patient.last_name %></td>
            <td><%= patient.dob %></td>
            <td><%= link_to "Show", patient, class: "btn btn-info btn-sm" %></td>
            <td><%= link_to "Edit", edit_patient_path(patient), class: "btn btn-warning btn-sm" %></td>
            <td><%= button_to "Destroy", patient, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %></td>
            </tr>
        <% end %>
    </tbody>
</table>
 <%= link_to "New patient", new_patient_path, class: "btn btn-primary mt-3" %>