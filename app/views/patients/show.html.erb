 <p id="notice"><%= notice %></p>
<div class="card p-4">
  <p>
    <strong>First name:</strong>
    <%= @patient.first_name %>
  </p>

  <p>
    <strong>Last name:</strong>
    <%= @patient.last_name %>
  </p>

  <p>
    <strong>Dob:</strong>
    <%= @patient.dob %>
  </p>
</div>

<%= link_to "Edit this patient", edit_patient_path(@patient), class: "btn btn-warning mt-3" %>
<%= link_to "Back to patients", patients_path, class: "btn btn-secondary mt-3" %>
